{
	"name": "helice",
	"version": "0.0.1",
	"description": "Typesafe PostgreSQL Query Builder",
	"main"   : "./build/index.js",
	"types"  : "./build/index.d.ts",
	"exports": {
		".": {
			"import": "./build/index.js",
			"types" : "./build/index.d.ts"
		}
	},
	"files": ["build"],
	"scripts": {
		"build"      : "tsc",
		"start"      : "node ./build",
		"test"       : "vitest run",
		"test:watch" : "vitest",
		"test:file"  : "tsx",
		"changeset"  : "changeset",
		"version"    : "changeset version",
		"release"    : "pnpm build && changeset publish"
	},
	"author": "",
	"type": "module",
	"license": "MIT",
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"tsx"            : "^4.22.3",
		"typescript"     : "^5.9.3",
		"vitest"         : "^4.1.7"
	}
}
